        <env name="APP_KEY" value="base64:qX4JBUxNuatW7iCl9D/kpMBQWt8TlIQcJSTfjHL/Yr0="/>
        <!-- Vite manifest is not present in tests; suppress the file_get_contents warning -->
        <env name="VITE_MANIFEST_FILE" value="false"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
